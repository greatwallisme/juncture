# Juncture Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (OpenAI-compatible) ---

# Required for examples 10-16 and deep-research:
OPENAI_API_KEY=sk-your-api-key-here

# Optional (defaults shown):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- Langfuse Cloud Export (Example 16) ---
#
# Optional. When set, example 16 automatically exports traces to Langfuse cloud.
# If not set, Langfuse export is silently skipped (local dashboard still works).
# Get your keys at: https://cloud.langfuse.com

# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- OpenTelemetry (telemetry_demo only) ---
#
# Optional. Only used by the Docker-based telemetry_demo (not example 16).
# Requires running: docker compose -f docker/telemetry/docker-compose.yml up -d

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=juncture-telemetry-demo

# --- Tavily Web Search ---
#
# Optional. Used by deep-research example for web search tool.
# Without it, the search tool errors gracefully.

# TAVILY_API_KEY=tvly-your-key-here
