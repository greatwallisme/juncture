# Juncture Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (OpenAI-compatible) ---

# Required:
OPENAI_API_KEY=sk-your-api-key-here

# Optional (defaults shown):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- OpenTelemetry ---

# OTLP endpoint for trace/metrics export (default: http://localhost:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name reported to OTel backend (default: juncture-telemetry-demo)
OTEL_SERVICE_NAME=juncture-telemetry-demo

# --- Tavily Web Search ---

# API key for Tavily search tool (optional, tool errors gracefully without it)
# TAVILY_API_KEY=tvly-your-key-here
